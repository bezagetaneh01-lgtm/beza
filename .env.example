# --- Auth mode ---
# "oauth" (recommended/default): Atlassian OAuth 2.0 (3LO) login flow.
# "basic" or "bearer": legacy API-token auth, only works if your Jira org allows classic API tokens.
JIRA_AUTH_MODE=oauth

# Used for "open in Jira" links in the dashboard (the domain you actually browse Jira with).
JIRA_BASE_URL=https://jira.prod.nationalgrid.com

# --- OAuth 2.0 (3LO) settings ---
# Create an app at https://developer.atlassian.com/console/myapps (see README for steps),
# add Jira API classic scopes: read:jira-work, write:jira-work, offline_access,
# and set its OAuth callback URL to match JIRA_OAUTH_REDIRECT_URI below.
JIRA_OAUTH_CLIENT_ID=paste-client-id-here
JIRA_OAUTH_CLIENT_SECRET=paste-client-secret-here
JIRA_OAUTH_REDIRECT_URI=http://localhost:3000/oauth/callback
JIRA_OAUTH_SCOPES=read:jira-work write:jira-work offline_access

# --- Legacy API-token settings (only used when JIRA_AUTH_MODE=basic or bearer) ---
JIRA_PAT=
JIRA_EMAIL=

# Default JQL shown on first load. Narrow this to your migration project/board, e.g.:
# project = GDMP AND (summary ~ "ODS" OR summary ~ "Snowflake") ORDER BY created DESC
JIRA_JQL=ORDER BY updated DESC

# Exact name of the Jira field (standard or custom) that holds migration status
MIGRATION_FIELD_NAME=Status

PORT=3000
